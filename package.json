{
  "name": "darktime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "darktime-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:swift": "swift build -c release",
    "build:app": "bash scripts/build-app.sh",
    "build:dmg": "bash scripts/create-dmg.sh",
    "build:all": "npm run build:app && npm run build",
    "mcp": "node dist/mcp-server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
